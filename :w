#ifndef SYNTH_H
#define SYNTH_H

#include "keyboard.h"
#include <cstdint>
#include <atomic>
#include <vector>


// parameters
struct Param {
    std::atomic<float> value;
    float min = 0.0f;
    float max = 1.0f;

    void set(float v);
    float get() const;
    Param& operator=(float v);
};


struct Oscillator {
    float phase = 0.0f;
    float freq = 440.0f;

    void set_frequency(float f);
    void reset();
    float sample(const float dt);
};

struct Voice {
    bool active = false;
    bool pressed = false;
    uint8_t velocity = 0;

    float time_pressed_s = 0.0f;
    float time_release_s = 0.0f;

    Oscillator osc;

    Voice(float freq);

    void note_on(uint8_t vel);
    void note_off();

    void update_timers(const float dt);
};


struct Envelope {
    struct Params {
        Param attack  {0.01f};
        Param decay   {1.0f};
        Param release {0.2f};
    } params;

    float get_coeff(const Voice& voice);
    bool is_done(const Voice& voice);
};



struct Compressor {

};

struct Synth : Keyboard {
    const uint8_t min_midi_id;
    const size_t sample_rate;
    const float period_s;

    Envelope e;
    std::vector<Voice> voices;

    Synth(uint8_t num_keys, uint8_t min_midi_id, float low_freq, size_t sample_rate);

    bool midi_id_in_range(uint8_t midi_id);

    void note_on(uint8_t, uint8_t) override;
    void note_off(uint8_t) override;

    void synthesise(float* buf, const size_t num_frames) override;
};

#endif
